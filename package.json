{
  "name": "kennyserpa-github-io",
  "version": "2.0.0",
  "private": true,
  "description": "Professional resume site for Kenny Serpa — Software Engineer",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "npm run lint:css && npm run lint:html",
    "lint:css": "stylelint \"src/**/*.css\"",
    "lint:html": "html-validate src/**/*.html",
    "format": "prettier --write \"src/**/*.{html,css,js,json,md}\" \"*.{json,md}\"",
    "format:check": "prettier --check \"src/**/*.{html,css,js,json,md}\" \"*.{json,md}\"",
    "validate": "npm run lint && npm run format:check"
  },
  "devDependencies": {
    "html-validate": "^9.0.0",
    "prettier": "^3.3.3",
    "stylelint": "^16.8.1",
    "stylelint-config-standard": "^36.0.1",
    "vite": "^6.4.3"
  },
  "dependencies": {},
  "engines": {
    "node": ">=18.0.0"
  }
}
